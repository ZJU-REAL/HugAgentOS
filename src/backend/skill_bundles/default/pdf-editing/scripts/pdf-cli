#!/bin/sh
# pdf-cli — global shim that routes to the pdf-editing skill's Python CLI
# (``scripts/cli.py``). Installed at /usr/local/bin/pdf-cli inside the
# sandbox and mcp container images so the agent can call ``pdf-cli merge …``
# without bookkeeping a long path.
#
# Resolution order (first existing wins):
#   1. /workspace/skills/pdf-editing/scripts/cli.py
#      — where ``register_bash`` materializes loaded skill files inside the
#        sandbox at runtime.
#   2. ${SKILL_DIR}/scripts/cli.py
#      — escape hatch for callers that pin an explicit skill dir.
#   3. /app/src/backend/agent_skills/skills/pdf-editing/scripts/cli.py
#      — the canonical in-repo path; works in the mcp / backend containers.
#   4. <this file>/../cli.py
#      — last-resort sibling lookup, e.g. when this shim is symlinked into
#        the user's PATH from a checkout.
set -e

resolve_self() {
    target="$0"
    while [ -L "$target" ]; do
        link=$(readlink "$target") || break
        case "$link" in
            /*) target="$link" ;;
            *)  target="$(dirname "$target")/$link" ;;
        esac
    done
    dirname "$target"
}

candidates="
/workspace/skills/pdf-editing/scripts/cli.py
${SKILL_DIR:-}/scripts/cli.py
/app/src/backend/agent_skills/skills/pdf-editing/scripts/cli.py
$(resolve_self 2>/dev/null)/cli.py
"

# Pick the right python3. In the opensandbox runtime the
# /opt/python/versions/cpython-*-linux-*-gnu/bin/python3 install is the one
# that has office_lib / pypdf / pdfplumber / matplotlib / etc. installed
# (see Dockerfile.opensandbox). The system /usr/bin/python3 has none of
# these. The session ENTRYPOINT normally fixes PATH, but harden the shim so
# it works no matter how we're invoked.
#
# The picker walks several candidates and picks the FIRST one that can
# actually ``import pypdf`` (the critical pdf-cli dep). On dev machines a
# stale /opt/python tree may exist without the office deps — silently
# falling through to ``python3`` from PATH (typically the user's conda /
# system env, which usually has pypdf) avoids a confusing
# "ModuleNotFoundError: No module named 'pypdf'" deep inside subcommand
# execution. PY_BIN escape hatch still wins so power users can pin a
# specific interpreter.
_has_pypdf() {
    "$1" -c "import pypdf" >/dev/null 2>&1
}

pick_python() {
    if [ -n "${PY_BIN:-}" ] && [ -x "$PY_BIN" ]; then
        echo "$PY_BIN"
        return
    fi
    for py in /opt/python/versions/cpython-*-linux-*-gnu/bin/python3 python3; do
        # glob may yield the literal pattern if no match — skip those
        case "$py" in *cpython-\**) continue ;; esac
        if command -v "$py" >/dev/null 2>&1 && _has_pypdf "$py"; then
            command -v "$py"
            return
        fi
    done
    # Last-resort fallback: the first interpreter found, even if pypdf is
    # missing. The CLI's downstream ModuleNotFoundError is then clear about
    # what's missing.
    for py in /opt/python/versions/cpython-*-linux-*-gnu/bin/python3; do
        if [ -x "$py" ]; then
            echo "$py"
            return
        fi
    done
    echo "python3"
}
PY="$(pick_python)"

for candidate in $candidates; do
    if [ -n "$candidate" ] && [ -f "$candidate" ]; then
        exec "$PY" "$candidate" "$@"
    fi
done

cat >&2 <<'EOF'
pdf-cli: cannot locate the pdf-editing skill's scripts/cli.py.
Searched (first match wins):
  - /workspace/skills/pdf-editing/scripts/cli.py
  - $SKILL_DIR/scripts/cli.py
  - /app/src/backend/agent_skills/skills/pdf-editing/scripts/cli.py
  - <shim's directory>/cli.py
If you're outside the sandbox / containers, point SKILL_DIR at the skill root
or invoke the underlying script directly: python <skill_dir>/scripts/cli.py
EOF
exit 127
