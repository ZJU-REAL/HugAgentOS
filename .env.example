# =============================================================================
# HugAgentOS 社区版环境配置示例
# 复制为 .env 后按需修改。单机最小可用配置开箱即用。
# =============================================================================

# ── 版本 ─────────────────────────────────────────────────────────────────────
JX_EDITION=ce

# ── 品牌（可自定义；协议要求保留 Powered-by 标识） ───────────────────────────
BRAND_PRODUCT_NAME=HugAgentOS
BRAND_ORG_NAME=

# ── 数据库（compose 内置 postgres；本地开发可用 sqlite） ─────────────────────
DATABASE_URL=postgresql+psycopg2://hugagent:hugagent@postgres:5432/hugagent
POSTGRES_USER=hugagent
POSTGRES_PASSWORD=hugagent
POSTGRES_DB=hugagent

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── 认证（社区版：本地账号注册登录 / mock 调试登录） ─────────────────────────
AUTH_MODE=mock
SSO_LOGIN_MODE=local

# ── LLM（模型接入） ──────────────────────────────────────────────────────────
# 模型配置存数据库（不走 env）：启动后在 Web「设置 → 系统管理 → 模型服务」
# 填 OpenAI 兼容端点（base_url / api_key / 模型名），或本地单机模式跑
# `hugagent onboard` 交互引导。

# ── 互联网搜索（可选；也可在「设置 → 系统管理 → 服务配置」里配，DB 优先） ──
# INTERNET_SEARCH_ENGINE=tavily        # tavily / baidu
# TAVILY_API_KEY=
# BAIDU_API_KEY=

# ── 存储（社区版：本地文件） ─────────────────────────────────────────────────
STORAGE_TYPE=local
# 宿主机存储目录的绝对路径（compose 挂载用）
HOST_STORAGE_PATH=./data/storage

# ── 沙箱（社区版：轻量无状态 script_runner） ─────────────────────────────────
SANDBOX_PROVIDER=script_runner
SANDBOX_RUNNER_URL=http://script-runner:8900

# ── 记忆（L1 画像默认开箱；L2/L3 需启用 compose 的 mem0 profile） ────────────
MEM0_ENABLED=false
# MEM0_GRAPH_ENABLED=false

# ── 服务端口 ─────────────────────────────────────────────────────────────────
BACKEND_PORT=3001
FRONTEND_PORT=3002
